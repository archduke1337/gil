# Normalize all text files to LF on check-in, convert to native on check-out
* text=auto eol=lf

# Force LF for scripts and source files
*.ts   text eol=lf
*.tsx  text eol=lf
*.mjs  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.sql  text eol=lf
*.sh   text eol=lf

# Declare binary files to prevent mangling
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
